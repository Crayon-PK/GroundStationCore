{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "STM32F407_Debug",
            "cwd": "${workspaceFolder}",
            "executable": "./build/firmware.elf", 
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "device": "STM32F407VG",
            "interface": "swd",
            "configFiles": [
                "interface/stlink.cfg", 
                "target/stm32f4x.cfg"   
            ],
            "runToEntryPoint": "main", 
            "showDevDebugOutput": "none",
            "armToolchainPath": "C:/Program Files (x86)/Arm/GNU Toolchain mingw-w64-i686-arm-none-eabi/bin",
            "gdbPath": "arm-none-eabi-gdb",
            "serverpath": "C:/openocd/xpack-openocd-0.12.0-7/bin/openocd.exe"
        }
    ]
}