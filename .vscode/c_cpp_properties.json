{
    "configurations": [
        {
            "name": "STM32F4",
            "includePath": [
                "${workspaceFolder}/App/**",
                "${workspaceFolder}/BSP/**",
                "${workspaceFolder}/Platform/STM32F4/**",
                "${workspaceFolder}/Middlewares/FreeRTOS/include",
                "${workspaceFolder}/Middlewares/FreeRTOS/port"
            ],
            "defines": [
                "USE_STDPERIPH_DRIVER",
                "STM32F40_41xxx"
            ],
            "compilerPath": "arm-none-eabi-gcc",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-arm"
        }
    ],
    "version": 4
}